{
  "name": "mouse",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify": "node .mouse_build/verify.mjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:dist": "pnpm run build && electron-builder",
    "cap:sync": "pnpm run build && pnpm exec cap sync",
    "cap:ios:sim": "pnpm run cap:sync && pnpm exec cap run ios --no-sync --target-name \"iPhone 17 Pro\" --target-name-sdk-version 26.2",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:open:android": "pnpm exec cap open android",
    "relay:local": "node relay/mouse-relay.mjs --local"
  },
  "build": {
    "appId": "com.mouse.app",
    "productName": "Mouse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "playwright": "^1.61.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "capacitor": "^0.5.6",
    "pyodide": "^0.28.3"
  }
}
