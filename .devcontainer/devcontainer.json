{
  "name": "Mouse",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "forwardPorts": [2222],
  "portsAttributes": {
    "2222": {
      "label": "Mouse relay",
      "visibility": "public"
    }
  },
  "postStartCommand": "bash -lc 'nohup npx -y @mouse-app/relay@latest >>/tmp/mouse-relay.log 2>&1 &'"
}
