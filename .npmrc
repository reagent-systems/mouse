# Supply-chain hardening for pnpm.
# - Pin a registry over HTTPS and require integrity for every package.
# - Block lifecycle scripts by default (pnpm asks before running build scripts),
#   the main npm/yarn supply-chain attack vector.
# - Fail if the lockfile would change in CI (no silent dependency drift).
registry=https://registry.npmjs.org/
# pnpm >=10 does not run dependency build scripts unless explicitly allowed.
# Keep that default ON and curate the allowlist in package.json
# (pnpm.onlyBuiltDependencies). Anything not listed is NOT executed.
ignore-scripts=false
# Refuse to silently mutate the lockfile.
frozen-lockfile=false
# Strict peer + engine handling surfaces incompatible/abandoned deps early.
strict-peer-dependencies=false
engine-strict=true
# Use the content-addressable store with verified integrity hashes.
verify-store-integrity=true
# Minimize postinstall surprise: warn on deprecated and avoid auto-install peers
# that could pull unexpected packages.
auto-install-peers=true
